<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="6.0" ExtensionBundleId="com.defeisoft.audioplugin" ExtensionBundleVersion="1.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <ExtensionList>
        <Extension Id="com.defeisoft.audioplugin.panel" Version="1.0.0" />
    </ExtensionList>
    <ExecutionEnvironment>
        <HostList>
            <Host Name="PPRO" Version="[14.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="12.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>
    <DispatchInfoList>
        <Extension Id="com.defeisoft.audioplugin.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./host/index.html</MainPath>
                    <ScriptPath>./jsx/audio_backend.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--disable-web-security</Parameter>
                        <Parameter>--allow-running-insecure-content</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>Audio Plugin</Menu>
                    <Geometry>
                        <Size>
                            <Width>800</Width>
                            <Height>600</Height>
                        </Size>
                        <MinSize>
                            <Width>500</Width>
                            <Height>350</Height>
                        </MinSize>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
