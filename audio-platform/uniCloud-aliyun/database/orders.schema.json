{
  "bsonType": "object",
  "required": ["user_id", "type", "amount"],
  "permission": {
    "read": "doc.user_id == auth.uid || 'admin_token' in auth.getToken()",
    "create": "auth.uid != null",
    "update": "'admin_token' in auth.getToken()",
    "delete": false
  },
  "properties": {
    "_id": {
      "bsonType": "string"
    },
    "user_id": {
      "bsonType": "string",
      "description": "用户ID",
      "label": "用户"
    },
    "order_no": {
      "bsonType": "string",
      "description": "订单号",
      "label": "订单号"
    },
    "type": {
      "bsonType": "string",
      "description": "套餐类型",
      "label": "套餐",
      "enum": [
        {"value": "monthly", "text": "月度会员"},
        {"value": "quarterly", "text": "季度会员"},
        {"value": "yearly", "text": "年度会员"},
        {"value": "permanent", "text": "永久会员"}
      ]
    },
    "amount": {
      "bsonType": "int",
      "description": "支付金额（分）",
      "label": "金额"
    },
    "status": {
      "bsonType": "string",
      "description": "订单状态",
      "label": "状态",
      "defaultValue": "pending",
      "enum": [
        {"value": "pending", "text": "待支付"},
        {"value": "paid", "text": "已支付"},
        {"value": "refunded", "text": "已退款"},
        {"value": "cancelled", "text": "已取消"}
      ]
    },
    "pay_method": {
      "bsonType": "string",
      "description": "支付方式",
      "label": "支付方式"
    },
    "trade_no": {
      "bsonType": "string",
      "description": "第三方交易号",
      "label": "交易号"
    },
    "paidAt": {
      "bsonType": "timestamp",
      "description": "支付时间",
      "label": "支付时间"
    },
    "refundAt": {
      "bsonType": "timestamp",
      "description": "退款时间",
      "label": "退款时间"
    },
    "refundReason": {
      "bsonType": "string",
      "description": "退款原因",
      "label": "退款原因"
    },
    "createdAt": {
      "bsonType": "timestamp",
      "label": "创建时间",
      "forceDefaultValue": {
        "$env": "now"
      }
    }
  }
}
